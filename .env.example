MWP_USE_INMEMORY_REPOSITORY=false
MWP_SUPABASE_URL=https://your-project.supabase.co
MWP_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
MWP_SUPABASE_SERVICE_KEY=your-service-role-or-secret-key

# Server runtime should prefer MWP_SUPABASE_SERVICE_KEY.
# Publishable key is for low-privilege/public-read scenarios only.
# Run sql/schema.sql first, then sql/rls_policies.sql.
# Keep .env local only and never commit it.
