          "type": "int",
          "required": true
        },
        "start_time": {
          "type": "string",
          "required": true
        },
        "correct_answer": {
          "type": "string",
          "required": true
        }
      },
      "difficulty_profiles": {
        "support": {
          "start_hour_range": [8, 12],
          "duration_hours_range": [1, 2],
          "allowed_start_minutes": [0, 15, 30, 45],
          "allowed_duration_minutess": [10, 20, 30, 40]
        },
        "core": {
          "start_hour_range": [8, 14],
          "duration_hours_range": [1, 3],
          "allowed_start_minutes": [0, 15, 30, 45],
          "allowed_duration_minutess": [10, 20, 30, 40]
        },
        "stretch": {
