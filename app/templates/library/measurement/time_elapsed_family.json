          "duration_hours_range": [1, 4],
          "allowed_start_minutes": [0, 15, 30, 45],
          "allowed_duration_minutess": [10, 20, 30, 40]
        }
      },
      "constraints": [
        {
          "type": "derived",
          "rule": "end_minute_raw = start_minute + duration_minutes"
        },
        {
          "type": "derived",
          "rule": "end_hour = start_hour + duration_hours + (1 if end_minute_raw >= 60 else 0)"
        },
        {
          "type": "derived",
          "rule": "end_minute = end_minute_raw - 60 if end_minute_raw >= 60 else end_minute_raw"
        },
        {
          "type": "derived",
          "rule": "start_time = f\"{start_hour:02d}:{start_minute:02d}\""
        },
        {
          "type": "derived",
          "rule": "correct_answer = f\"{end_hour:02d}:{end_minute:02d}\""
        },
        {
          "type": "expression",
          "rule": "end_hour <= 19"
        }
      ],
      "answer_formula": {
        "type": "expression",
        "value": "correct_answer"
      },
      "distractor_rules": [],
      "explanation_template": "Add the hours and minutes. If the minutes reach 60 or more, exchange 60 minutes for 1 extra hour.",
