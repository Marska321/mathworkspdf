      "pattern_code": "direct_compute",
      "name": "Convert length units",
      "question_type": "fill_blank",
      "template_text": "Convert {base_value} {source_unit} to {target_unit}.",
      "instructions_template": null,
      "variable_schema": {
        "base_value": {
          "type": "int",
          "required": true
        },
        "conversion_type": {
          "type": "enum",
          "required": true,
          "values": [
            "cm_to_mm",
            "m_to_cm"
          ]
        },
        "source_unit": {
          "type": "string",
          "required": true
        },
        "target_unit": {
          "type": "string",
          "required": true
        },
        "correct_answer": {
          "type": "int",
          "required": true
        },
        "ruler_max": {
          "type": "int",
          "required": true
        },
        "highlight_value": {
          "type": "int",
          "required": true
        },
        "tick_step": {
          "type": "int",
          "required": true
        }
      },
      "difficulty_profiles": {
        "support": {
          "base_value_range": [
            2,
            20
          ],
          "allowed_conversion_types": [
            "cm_to_mm"
          ]
        },
        "core": {
          "base_value_range": [
            2,
            50
          ],
          "allowed_conversion_types": [
            "cm_to_mm",
            "m_to_cm"
          ]
        },
        "stretch": {
          "base_value_range": [
            5,
            90
          ],
          "allowed_conversion_types": [
            "cm_to_mm",
            "m_to_cm"
          ]
        }
      },
      "constraints": [
        {
          "type": "derived",
          "rule": "source_unit = 'cm' if conversion_type == 'cm_to_mm' else 'm'"
        },
        {
          "type": "derived",
          "rule": "target_unit = 'mm' if conversion_type == 'cm_to_mm' else 'cm'"
        },
        {
          "type": "derived",
          "rule": "correct_answer = base_value * 10 if conversion_type == 'cm_to_mm' else base_value * 100"
        },
        {
          "type": "derived",
          "rule": "tick_step = 1 if base_value <= 20 else 5"
        },
        {
          "type": "derived",
          "rule": "highlight_value = base_value"
        },
        {
          "type": "derived",
          "rule": "ruler_max = max(10, ((base_value + tick_step - 1) // tick_step + 1) * tick_step)"
        }
      ],
      "answer_formula": {
        "type": "expression",
        "value": "correct_answer"
      },
      "distractor_rules": [],
      "explanation_template": "Match the starting unit to the correct conversion factor, then multiply the value.",
      "rendering": {
        "visual_type": "measurement_ruler",
        "layout_hint": "full_width",
        "visual_variable_map": {
          "unit": "source_unit",
          "max_value": "ruler_max",
          "highlight_value": "highlight_value",
          "tick_step": "tick_step"
        }
      },
      "theme_supported": false,
      "visual_supported": true,
      "misconception_targets": [
        "unit_confusion"
      ],
      "active": true
    },
