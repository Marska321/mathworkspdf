            "cm"
          ],
          "major_value_range": [
            2,
            8
          ],
          "minor_ticks_range": [
            1,
            9
          ]
        },
        "core": {
          "allowed_units": [
            "cm",
            "mm"
          ],
          "major_value_range": [
            2,
            10
          ],
          "minor_ticks_range": [
            1,
            9
          ]
        },
        "stretch": {
          "allowed_units": [
            "cm",
            "mm"
          ],
          "major_value_range": [
            3,
            12
          ],
          "minor_ticks_range": [
            1,
            9
          ]
        }
      },
      "constraints": [
        {
          "type": "derived",
          "rule": "tick_step = 1 if unit == 'cm' else 10"
        },
        {
          "type": "derived",
          "rule": "ruler_max = major_value + 3 if unit == 'cm' else (major_value * 10) + 30"
        },
        {
          "type": "derived",
          "rule": "highlight_value = round(major_value + (minor_ticks / 10), 1) if unit == 'cm' else (major_value * 10) + minor_ticks"
        },
        {
          "type": "derived",
          "rule": "correct_answer = f'{highlight_value:.1f}'.rstrip('0').rstrip('.') if unit == 'cm' else str(int(highlight_value))"
        },
        {
          "type": "expression",
          "rule": "minor_ticks != 0"
        },
        {
          "type": "expression",
          "rule": "highlight_value < ruler_max"
        }
      ],
      "answer_formula": {
        "type": "expression",
        "value": "correct_answer"
      },
      "distractor_rules": [],
      "explanation_template": "Start measuring at 0 and count the small tick marks carefully to reach the exact measurement.",
      "rendering": {
        "visual_type": "measurement_ruler",
