          "type": "int",
          "required": true
        },
        "minor_ticks": {
          "type": "int",
          "required": true
        },
        "tick_step": {
          "type": "int",
          "required": true
        },
        "ruler_max": {
          "type": "int",
          "required": true
        },
        "highlight_value": {
          "type": "float",
          "required": true
        },
        "correct_answer": {
          "type": "string",
          "required": true
        }
      },
      "difficulty_profiles": {
