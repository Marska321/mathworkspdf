      "pattern_code": "visual_identification",
      "name": "Read the measurement on a ruler",
      "question_type": "visual",
      "template_text": "Look at the ruler below. What measurement is shown by the arrow? Give your answer in {unit}.",
      "instructions_template": null,
      "variable_schema": {
